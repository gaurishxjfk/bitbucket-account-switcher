{
  "manifest_version": 3,
  "name": "Bitbucket Account Switcher",
  "version": "2.0",
  "permissions": ["storage"],
  "host_permissions": ["*://bitbucket.org/*"],
  "content_scripts": [
    {
      "matches": ["*://bitbucket.org/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
